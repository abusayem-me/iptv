rules_version = '2';

// One document per signed-in user: userSettings/{uid}
// Tighten further once you add server validation or custom claims.
service cloud.firestore {
  match /databases/{database}/documents {
    match /userSettings/{userId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;

      match /devices/{deviceId} {
        allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Global stream live/dead labels — shared by all signed-in users.
    match /streamHealth/{streamId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.resource.data.keys().hasAll(['streamUrl', 'categoryId', 'status', 'source'])
        && request.resource.data.status in ['live', 'dead']
        && request.resource.data.source in ['check', 'playback'];
    }

    match /categoryHealth/{categoryId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null;
    }
  }
}
