{
  "compilerOptions": {
    "strict": true,
    "target": "es2022",
    "module": "nodeNext",
    "moduleResolution": "nodeNext",
    "typeRoots": [
      "./scripts/types",
      "./node_modules/@types"
    ],
    "esModuleInterop": true,
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "ts-node": {
    "esm": true,
    "transpileOnly": true
  },
  "files": [
    "node_modules/jest-expect-message/types/index.d.ts"
  ],
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
